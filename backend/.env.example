# ─────────────────────────────────────────────────────────
# Zero Sum Times — Backend Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env:
#   cp backend/.env.example backend/.env
#
# The app works WITHOUT any API keys — you'll get market
# data, charts, heatmaps, and everything except AI-generated
# analysis summaries. Fill in the OpenAI key only if you
# want those.
# ─────────────────────────────────────────────────────────

# ── OpenAI (optional) ───────────────────────────────────
# Required only for AI-generated stock analysis.
# Leave blank to skip AI features — everything else works.
OPENAI_API_KEY=
OPENAI_ORG_ID=
ANALYSIS_MODEL=gpt-4o
ANALYSIS_CACHE_HOURS=24
